# ──────────────────────────────────────────────────────────────────────────
# RouwKompas environment configuration
# Copy this file to ".env" and fill in real values for production.
# The app runs fully WITHOUT any of these set (safe local/demo defaults).
# ──────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# Branding
SITE_NAME=RouwKompas
COACH_NAME=Anna de Vries
SUPPORT_EMAIL=anna@rouwkompas.nl

# Admin dashboard login (CHANGE THESE in production)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please

# ── Booking (Calendly or equivalent) ──────────────────────────────────────
# Paste your Calendly scheduling URL. When set, it is embedded on /booking.
# When empty, an internal "request a time" fallback form is shown instead.
CALENDLY_URL=

# ── Email (Resend) ────────────────────────────────────────────────────────
# When RESEND_API_KEY is set, transactional + follow-up emails are sent via
# the Resend HTTP API. When empty, emails are written to data/outbox.json
# (and logged) so the automation flow is fully demonstrable offline.
RESEND_API_KEY=
EMAIL_FROM="RouwKompas <noreply@rouwkompas.nl>"

# Notify the coach whenever a new lead arrives (leave empty to disable)
COACH_NOTIFICATION_EMAIL=anna@rouwkompas.nl

# Follow-up timing (Email 2). Default 48 hours. Lower it to test quickly.
FOLLOWUP_DELAY_HOURS=48

# ── Database ──────────────────────────────────────────────────────────────
# Default storage is a local JSON file (data/leads.json) — zero-dependency.
# To migrate to Supabase later, set these and swap the adapter in src/db.js.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Ob-Audire (Petra Mollet) — omgevingsconfiguratie
# Kopieer dit bestand naar ".env" en vul echte waarden in voor productie.
# De app draait volledig ZONDER dat een van deze is ingesteld (veilige demo).
# Teksten/branding staan in src/content.js; hier staan techniek + geheimen.
# ──────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# Branding (zie src/content.js voor alle teksten)
SITE_NAME=Ob-Audire
COACH_NAME=Petra Mollet
SUPPORT_EMAIL=info@ob-audire.nl

# Admin-dashboard login (WIJZIG DIT in productie)
ADMIN_USER=petra
ADMIN_PASSWORD=wijzig-mij-aub

# ── Boeken (Calendly of vergelijkbaar) ────────────────────────────────────
# Plak hier je Calendly-link. Indien ingevuld wordt die op /afspraak getoond.
# Leeg = een intern "vraag een gesprek aan"-formulier wordt getoond.
CALENDLY_URL=

# Optionele, privacyvriendelijke bezoekersstatistieken via Plausible.
# Vul je domein in (bijv. leads.ob-audire.nl) om het script te laden; leeg = uit.
PLAUSIBLE_DOMAIN=

# ── E-mail (Resend) ───────────────────────────────────────────────────────
# Met RESEND_API_KEY ingevuld gaan e-mails via de Resend API. Leeg = e-mails
# worden naar data/outbox.json geschreven (en gelogd), zodat de flow offline
# volledig te demonstreren is.
RESEND_API_KEY=
EMAIL_FROM="Ob-Audire <noreply@ob-audire.nl>"

# Petra een melding sturen bij elke nieuwe lead (leeg = uit)
COACH_NOTIFICATION_EMAIL=info@ob-audire.nl

# Timing van de opvolgmail (e-mail 2). Standaard 48 uur. Verlaag om te testen.
FOLLOWUP_DELAY_HOURS=48

# ── Database ──────────────────────────────────────────────────────────────
# Standaardopslag is een lokaal JSON-bestand (data/leads.json) — zonder deps.
# Migreren naar Supabase later: vul deze in en wissel de adapter in src/db.js.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
